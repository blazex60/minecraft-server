# このファイルを .env にコピーして値を埋めてください

# Tailscale IP（管理者アクセス用）
TAILSCALE_IP=your_tailscale_ip_here

# Minecraft オペレーター（カンマ区切りで複数指定可）
MC_OPS=your_username_here

# Minecraft RCON パスワード（バックアップ用）
RCON_PASSWORD=your_rcon_password_here

# playit.gg シークレットキー（https://playit.gg でエージェント作成後に取得）
PLAYIT_SECRET=your_secret_here
